# PipelineMedic LLM provider (OpenAI-compatible). Copy to `.env` and edit.
# `.env` is gitignored — never commit real keys.

# --- Local dev (default): Ollama ---
PM_LLM_BASE_URL=http://localhost:11434/v1
PM_LLM_API_KEY=ollama
PM_LLM_MODEL=qwen2.5:3b

# --- Production: Qwen Cloud / DashScope (swap to these when credits are ready) ---
# PM_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# PM_LLM_API_KEY=sk-your-dashscope-key
# PM_LLM_MODEL=qwen-max
